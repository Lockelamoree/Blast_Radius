OPENAI_API_KEY=
BLAST_RADIUS_DATABASE=blast_radius.db
# Reasoning is graded by GPT-5.6 automatically when OPENAI_API_KEY is set.
# LIVE_GENERATION controls only fresh scenario generation.
BLAST_RADIUS_LIVE_GENERATION=false
BLAST_RADIUS_SESSION_TTL_MINUTES=180
BLAST_RADIUS_DAILY_LLM_BUDGET=100
BLAST_RADIUS_SESSION_CREATE_LIMIT_PER_HOUR=12
BLAST_RADIUS_ROUND_REQUEST_LIMIT_PER_MINUTE=30
BLAST_RADIUS_SESSION_ROUND_REQUEST_CAP=30
